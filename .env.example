# Discord bot credentials
DISCORD_TOKEN=          # Bot token from Discord Developer Portal
DISCORD_CLIENT_ID=      # Application (client) ID
DISCORD_GUILD_ID=       # Guild (server) ID to register slash commands to

# Channel configuration
EVENTS_CHANNEL_ID=      # Comma-separated channel IDs for the weekly events cron post

# Database
DATABASE_URL=           # PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/db)

# Runtime
NODE_ENV=development    # development | production
LOG_LEVEL=info          # debug | info | warn | error
WEB_PORT=3000           # HTTP port for the web server (Phase 4)
WEB_ADMIN_TOKEN=        # Admin token for protected web endpoints (required in Phase 4)

# Scraper
SCRAPER_CRON=0 */6 * * *  # Cron expression for the scraper job (default: every 6 hours)
